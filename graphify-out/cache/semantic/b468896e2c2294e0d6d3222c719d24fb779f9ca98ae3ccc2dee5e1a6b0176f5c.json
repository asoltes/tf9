{"nodes": [{"id": "references_extraction_spec_subagent_prompt", "label": "Extraction Subagent Prompt Template", "file_type": "concept", "source_file": ".claude/skills/graphify/references/extraction-spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "references_extraction_spec_confidence_rubric", "label": "Discrete Confidence Score Rubric", "file_type": "rationale", "source_file": ".claude/skills/graphify/references/extraction-spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Models follow discrete rubrics better than continuous ranges; production data showed a bimodal collapse (>50% at 0.5, >40% at 0.85+) when given a range, so the spec mandates exact values 0.95/0.85/0.75/0.65/0.55."}, {"id": "references_extraction_spec_node_id_format", "label": "Deterministic Node ID Format", "file_type": "concept", "source_file": ".claude/skills/graphify/references/extraction-spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Semantic IDs must match the AST extractor's parent-dir + filename-stem format; using just the filename or the full path creates orphan ghost-duplicate nodes, and chunk-number suffixes break determinism."}], "edges": [{"source": "references_extraction_spec_confidence_rubric", "target": "references_extraction_spec_subagent_prompt", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/references/extraction-spec.md", "source_location": null, "weight": 1.0}, {"source": "references_extraction_spec_node_id_format", "target": "graphify_skill_ast_extraction", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".claude/skills/graphify/references/extraction-spec.md", "source_location": null, "weight": 1.0}, {"source": "graphify_skill_audit_tr