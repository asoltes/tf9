": null, "rationale": "Subagents must be dispatched in a single message to run in parallel and must be general-purpose (not read-only Explore) because they write chunk JSON files to disk as the success signal."}, {"id": "graphify_skill_extraction_cache", "label": "Semantic Extraction Cache", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step B0", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "graphify_skill_fast_path_query", "label": "Fast Path: Query Existing Graph", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "What You Must Do When Invoked", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "If graphify-out/graph.json already exists and the request is a natural-language question, skip rebuild entirely and query directly - the graph is persistent across sessions."}, {"id": "graphify_skill_community_labeling", "label": "Community Labeling (Step 5)", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 5", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "graphify_skill_cost_tracker", "label": "Cumulative Token Cost Tracker", "file_type": "concept", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Step 9", "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "graphify_skill_honesty_rules", "label": "Graphify Honesty Rules", "file_type": "rationale", "source_file": ".claude/skills/graphify/SKILL.md", "source_location": "Honesty Rules", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Never invent edges, always show token cost, never hide raw cohesion scores - the graph's value depends on a trustworthy audit trail."}], "edges": [{"source": "graphify_skill_pipeline", "target": "graphify_skill_ast_extraction", "rela