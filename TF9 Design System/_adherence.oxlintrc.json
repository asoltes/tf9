{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "ui_kits/tf9/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Open Sans))/i]",
        "message": "Font not provided by the design system. Available: Open Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|dot|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, dot, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:default|blue|green|amber|red|purple|outline)$/]",
        "message": "<Badge> variant must be one of 'default' | 'blue' | 'green' | 'amber' | 'red' | 'purple' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|disabled|loading|icon|onClick|type|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, disabled, loading, icon, onClick, type, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|normal|danger|danger-outline|ghost|link|icon)$/]",
        "message": "<Button> variant must be one of 'primary' | 'normal' | 'danger' | 'danger-outline' | 'ghost' | 'link' | 'icon'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Button> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CommandBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:command|size|key|ref|className|style|children)$/]",
        "message": "<CommandBadge> doesn't accept that prop. Declared props: command, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='CommandBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<CommandBadge> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|value|onChange|placeholder|disabled|mono|label|hint|error|id|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: type, value, onChange, placeholder, disabled, mono, label, hint, error, id."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:text|password|email|search|url|number)$/]",
        "message": "<Input> type must be one of 'text' | 'password' | 'email' | 'search' | 'url' | 'number'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RunStatus'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|showIcon|size|key|ref|className|style|children)$/]",
        "message": "<RunStatus> doesn't accept that prop. Declared props: status, showIcon, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='RunStatus'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:running|success|partial_success|failed|cancelled|denied)$/]",
        "message": "<RunStatus> status must be one of 'running' | 'success' | 'partial_success' | 'failed' | 'cancelled' | 'denied'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RunStatus'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<RunStatus> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Skeleton'] > JSXAttribute > JSXIdentifier[name!=/^(?:lines|widths|height|gap|key|ref|className|style|children)$/]",
        "message": "<Skeleton> doesn't accept that prop. Declared props: lines, widths, height, gap."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|size|pulse|key|ref|className|style|children)$/]",
        "message": "<StatusDot> doesn't accept that prop. Declared props: status, size, pulse."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusDot'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:running|success|failed|warning|neutral|prod|staging|dev|global)$/]",
        "message": "<StatusDot> status must be one of 'running' | 'success' | 'failed' | 'warning' | 'neutral' | 'prod' | 'staging' | 'dev' | 'global'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
